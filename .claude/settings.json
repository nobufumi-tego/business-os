{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git checkout*)",
      "Bash(git revert*)",
      "Bash(uv run*)",
      "Bash(uv sync*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git remote add*)",
      "Bash(git remote set-url*)",
      "Bash(git add inputs/*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {}
}
